# LLM 백엔드는 각 CLI 도구를 통해 동작합니다. API 키 설정이 불필요합니다.
#
#   --llm claude  →  claude CLI (Claude Code)   가 인증을 자체 처리합니다.
#   --llm gemini  →  gemini CLI                 가 인증을 자체 처리합니다.
#   --llm openai  →  codex CLI (OpenAI Codex)   가 인증을 자체 처리합니다.
#
# 각 CLI가 PATH에 있어야 합니다.
# 예: which claude / which gemini / which codex

# 기본 LLM 백엔드 (선택사항)
DEFAULT_LLM=claude
